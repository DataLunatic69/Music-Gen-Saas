# ---------------------------------------------------------------------------
# music-generation-secret  (Modal Secret — set these values)
# modal secret create music-generation-secret \
#   SUPABASE_URL=... SUPABASE_KEY=... SUPABASE_BUCKET=... OPENAI_API_KEY=...
# ---------------------------------------------------------------------------

# Supabase project URL  (Settings → API → Project URL)
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase service-role key  (Settings → API → service_role — keep secret!)
SUPABASE_KEY=your-service-role-key

# Name of the Supabase Storage bucket for audio + cover art uploads
SUPABASE_BUCKET=music-gen

# Groq API key  (used for lyrics/prompt/category generation via llama-3.3-70b-versatile)
GROQ_API_KEY=gsk_...

# ---------------------------------------------------------------------------
# Modal CLI authentication  (local machine only — NOT in the Modal Secret)
# ---------------------------------------------------------------------------
MODAL_TOKEN_ID=your-modal-token-id
MODAL_TOKEN_SECRET=your-modal-token-secret
